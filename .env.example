# Copy this file to .env and fill in your values for local testing.
# NEVER commit .env to GitHub — it is listed in .gitignore.
# In Railway, set these in the Variables tab instead.

# Required
TUYA_API_KEY=your_api_key_here
TUYA_API_SECRET=your_api_secret_here
TUYA_DEVICE_ID=your_device_id_here

# Optional (defaults shown)
TUYA_API_REGION=us
TEMP_ON_THRESHOLD=65.0
CHECK_INTERVAL=1800
